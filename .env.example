# Compose / Makefile host-side env (Issue #798 Phase 4)
# Copy to `.env` and set RUNFLOW_ROOT to your local Runflow data directory.
# Docker Compose reads `.env` for volume interpolation; do not commit `.env`.

# Absolute path on the host that should mount at /app/runflow inside the container.
# Examples:
#   RUNFLOW_ROOT=/Users/you/Documents/runflow
#   RUNFLOW_ROOT=./runflow
RUNFLOW_ROOT=./runflow
